### 3. Update `App.tsx` (The Shared State Parent)

We initialize the state `sortDirection` here and pass both the value and the change handler down to our two sibling components.

```tsx
// App.tsx
import React, { useState } from 'react';
import Navbar from './components/Navbar';
import Taskboard from './components/Taskboard';
import type { SortDirection } from './components/types';

function App() {
  const [isAdding, setIsAdding] = useState<boolean>(false);
  const [sortDirection, setSortDirection] = useState<SortDirection>('asc'); // 👈 Shareable state

  return (
    <div>
      {/* 1. Navbar sets the sorting state */}
      <Navbar 
        onAddTaskClick={() => setIsAdding(true)} 
        sortDirection={sortDirection}
        onSortChange={setSortDirection}
      />
      
      {/* 2. Taskboard receives the sorting state */}
      <Taskboard 
        showAddInput={isAdding} 
        onTaskCreated={() => setIsAdding(false)} 
        sortDirection={sortDirection} 
      />
    </div>
  );
}

export default App;

```

