### 4. Update `Taskboard.tsx` (Sorting Logic)

Now, we update our dynamic `sort` algorithm to look at `sortDirection` when sorting the tasks before rendering them.

```tsx
// Taskboard.tsx
import React, { useState } from 'react';
import TaskColumn from './TaskColumn';
import type { TaskItem, Category, SortDirection } from './types';

interface TaskboardProps {
  showAddInput: boolean;
  onTaskCreated: () => void;
  sortDirection: SortDirection; // 👈 Receive sorting direction from parent
}

export default function Taskboard({ showAddInput, onTaskCreated, sortDirection }: TaskboardProps) {
  const [tasks, setTasks] = useState<TaskItem[]>([
    { id: '1', title: 'Learn React State', category: 'Todo', dueDate: '2026-07-20', subtask: [] },
    { id: '2', title: 'Build Todo App', category: 'In Progress', dueDate: '2026-07-15', subtask: [] },
    { id: '3', title: 'Master lifting state up', category: 'Done', subtask: [] }
  ]);
  
  const [searchQuery, setSearchQuery] = useState<string>('');

  // ... (keep handleAddTask, handleUpdateTask, etc. exactly the same) ...

  const categories: Category[] = ['Todo', 'In Progress', 'Done'];

  // 1. FILTER by Search
  const searchedTasks = tasks.filter(task => 
    task.title.toLowerCase().includes(searchQuery.toLowerCase())
  );

  // 2. SORT dynamically based on sortDirection (Derived State)
  const sortedAndSearchedTasks = [...searchedTasks].sort((a, b) => {
    if (a.dueDate && b.dueDate) {
      const timeA = new Date(a.dueDate).getTime();
      const timeB = new Date(b.dueDate).getTime();
      
      // Toggle sort math based on asc vs desc
      return sortDirection === 'asc' ? timeA - timeB : timeB - timeA;
    }
    
    // Always push tasks without dates to the very bottom
    if (a.dueDate) return -1; 
    if (b.dueDate) return 1;
    return 0;
  });

  return (
    <div style={{ padding: '20px', fontFamily: 'sans-serif' }}>
      {/* Search Input */}
      <div style={{ marginBottom: '20px' }}>
        <input 
          type="text" 
          placeholder="🔍 Search tasks..." 
          value={searchQuery} 
          onChange={(e) => setSearchQuery(e.target.value)} 
          style={{ padding: '8px 12px', width: '300px', borderRadius: '4px', border: '1px solid #ccc' }}
        />
      </div>

      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start' }}>
        {categories.map(category => {
          const filteredTasks = sortedAndSearchedTasks.filter(t => t.category === category);
          
          return (
            <TaskColumn 
              key={category}
              title={category}
              tasks={filteredTasks}
              onUpdateTask={handleUpdateTask}
              onDeleteTask={handleDeleteTask}
              onAddTask={handleAddTask}
              onAddSubtask={handleAddSubtask}
              onUpdateSubtask={handleUpdateSubtask}
              onDeleteSubtask={handleDeleteSubtask}
              showAddInput={showAddInput} 
            />
          );
        })}
      </div>
    </div>
  );
}

```

---

## 💡 What Makes This Solution So Clean?

By relying on **derived state** (calculating the sort on-the-fly inside the render process rather than storing a separate `sortedTasks` array in React's memory), you get maximum performance with zero sync issues.

When you change the dropdown option in the `Navbar`, `App.tsx` updates its state, triggering a re-render. `Taskboard` receives the new `sortDirection` and immediately reshuffles the array—your list reorganizes instantly!
